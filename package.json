{
  "name": "lingshi-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "npm run build && node --test dist/**/*.test.js",
    "dashboard:dev": "vite --config src/dashboard/vite.config.ts",
    "dashboard:build": "vite build --config src/dashboard/vite.config.ts",
    "dashboard:preview": "vite preview --config src/dashboard/vite.config.ts",
    "smoke:task-state": "tsx scripts/task-state-smoke.ts",
    "smoke:task-lifecycle": "tsx scripts/task-lifecycle-smoke.ts",
    "stress:lifecycle-settlement": "tsx scripts/lifecycle-settlement-stress.ts",
    "check:indexes": "tsx scripts/index-sanity.ts",
    "check:indexes:strict": "tsx scripts/index-sanity.ts --fail-on-warn",
    "test:integration": "tsx scripts/integration-gate.ts",
    "test:merge-gate": "tsx scripts/merge-gate.ts",
    "release:readiness": "tsx scripts/release-readiness.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "12.6.2",
    "echarts": "^5.5.1",
    "fastify": "^5.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.4.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vite": "^6.0.6"
  }
}
